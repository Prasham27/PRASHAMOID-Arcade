# All vars are optional. Site builds + runs without any of them.
# Each feature gracefully shows "OFFLINE" if its keys aren't set.

# Site URL — used for OG image, sitemap, robots
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# --- Global high-score leaderboard (Supabase, free tier) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin panel (use the same values as your Batman site!) ---
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- Contact form (Resend, free 100 emails/day) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# --- GitHub (optional — boosts rate limit 60 -> 5000 req/hr) ---
GITHUB_TOKEN=

# --- Future Arcade Attendant chat (Gemini) ---
GEMINI_API_KEY=
